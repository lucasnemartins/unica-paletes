PORT=3001

# MySQL (local ou na nuvem)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=dbunicapaletes

# MongoDB Atlas (Dashboard → Connect → Drivers). Obrigatório para o app.
# Também aceito: MONGO_URI (mesmo valor).
# MONGODB_URI=mongodb+srv://USUARIO:SENHA@cluster0.xxxxx.mongodb.net/dbunicapaletes?retryWrites=true&w=majority
MONGODB_URI=

# URL pública do backend (uploads). Em teste local:
HOST_URL=http://localhost:3001

# Cloudflare Images (opcional)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_HASH=
